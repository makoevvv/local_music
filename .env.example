# === Backend ===
APP_ENV=development
APP_SECRET_KEY=change-me-please-32-bytes-min
APP_HOST=0.0.0.0
APP_PORT=8000

# JWT
JWT_SECRET=change-me-jwt-secret
JWT_ALG=HS256
JWT_ACCESS_TTL_MIN=60
JWT_REFRESH_TTL_DAYS=30

# Регистрация
REGISTRATION_ENABLED=true
REGISTRATION_INVITE_ONLY=true
INVITE_CODES=friend1,friend2,friend3

# === БД и кеш ===
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=local_music
POSTGRES_USER=music
POSTGRES_PASSWORD=change-me-db
DATABASE_URL=postgresql+asyncpg://music:change-me-db@postgres:5432/local_music

REDIS_URL=redis://redis:6379/0

# === Хранилище аудио ===
# local — файлы на диске; s3 — S3-совместимое (MinIO)
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=/data/storage

MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=music

# === Политика источников (docs/06-music-sourcing.md) ===
# Разрешить ли использование restricted/«пиратских» источников (tier 4) как fallback.
# В личном проекте обычно true; для пользователей с prefer_open_only=true игнорируется.
RESTRICTED_SOURCES_ENABLED=true
# Опц. адаптер Telegram-источников (mp3-вложения из каналов). По умолчанию выключен.
TELEGRAM_SOURCE_ENABLED=false
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION_PATH=/data/storage/telegram.session

# === Внешние API ===
# MusicBrainz / Last.fm — метаданные
LASTFM_API_KEY=
MUSICBRAINZ_USER_AGENT=local-music/0.1 (you@example.com)

# Shazam (RapidAPI)
SHAZAM_RAPIDAPI_KEY=
SHAZAM_RAPIDAPI_HOST=shazam.p.rapidapi.com

# YouTube Data API (опционально, для метаданных)
YOUTUBE_API_KEY=

# === Импорт из внешних сервисов (docs/17-external-imports.md) ===
# 32 байта в base64 — мастер-ключ для AES-GCM шифрования токенов в external_accounts.
# Сгенерировать: python -c "import os,base64;print(base64.b64encode(os.urandom(32)).decode())"
EXTERNAL_TOKENS_KEY=
EXTERNAL_TOKENS_KEY_PREV=

# Spotify OAuth (https://developer.spotify.com/dashboard)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:8000/api/v1/import/callback/spotify

# Yandex Music (неофициальный API, токен задаёт пользователь в UI)
# Apple Music — Developer JWT (ES256)
APPLE_MUSIC_TEAM_ID=
APPLE_MUSIC_KEY_ID=
APPLE_MUSIC_PRIVATE_KEY_PATH=

# === Web ===
WEB_API_BASE=http://localhost:8000
